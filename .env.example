# Azure OpenAI (chat + embeddings)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
# Defina como false se o modelo do deployment de chat rejeitar temperature != 1
# (ex. família de modelos "reasoning" como o1/gpt-5)
AZURE_OPENAI_SUPPORTS_TEMPERATURE=false
# Web search
TAVILY_API_KEY=

# Vector DB (Chroma)
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_COLLECTION=faq_docs

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=assistant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/assistant

# Weather (Open-Meteo não exige API key)
WEATHER_RATE_LIMIT_PER_MINUTE=10
WEB_SEARCH_RATE_LIMIT_PER_MINUTE=10

# App
LOG_LEVEL=INFO
# LangSmith tracing (opcional — observabilidade/bônus do desafio)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=
